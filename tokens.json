{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "txn2 design tokens. DTCG-compliant sidecar to DESIGN.md. Source of truth: static/css/site.css.",

  "color": {
    "ink":       { "$type": "color", "$value": "#0B0B09", "$description": "warm near-black canvas" },
    "ink-2":     { "$type": "color", "$value": "#131310", "$description": "surface, body gradient endpoint" },
    "ink-3":     { "$type": "color", "$value": "#1B1A15", "$description": "card background, mermaid background" },
    "rule":      { "$type": "color", "$value": "#2A2922", "$description": "subtle borders, dashed dividers" },
    "rule-2":    { "$type": "color", "$value": "#3A3830", "$description": "stronger borders, button outlines" },
    "paper":     { "$type": "color", "$value": "#ECE3CE", "$description": "warm parchment, body text" },
    "paper-dim": { "$type": "color", "$value": "#C9C0AB", "$description": "secondary body text" },
    "mute":      { "$type": "color", "$value": "#968F80", "$description": "muted text. WCAG AA at small sizes on ink (5.79:1)." },
    "mute-2":    { "$type": "color", "$value": "#5A554B", "$description": "ultra-faint marks, blueprint crosshair lines" },
    "signal":    { "$type": "color", "$value": "#FF5A1F", "$description": "signal orange. Primary accent. Used sparingly." },
    "signal-2":  { "$type": "color", "$value": "#FF8A4C", "$description": "signal hover state" },
    "acid":      { "$type": "color", "$value": "#E1FF6E", "$description": "electric lime. Terminal success only." },
    "cool":      { "$type": "color", "$value": "#6FE1FF", "$description": "coolant blue. Reserved." }
  },

  "font": {
    "serif": {
      "$type": "fontFamily",
      "$value": ["Fraunces", "Times New Roman", "serif"],
      "$description": "Display. Italic with opsz/wght variation, weights 300-700."
    },
    "sans": {
      "$type": "fontFamily",
      "$value": ["Instrument Sans", "-apple-system", "Helvetica Neue", "sans-serif"],
      "$description": "Body and UI. Roman only, weights 400-700."
    },
    "mono": {
      "$type": "fontFamily",
      "$value": ["JetBrains Mono", "ui-monospace", "SF Mono", "Menlo", "monospace"],
      "$description": "Rail, labels, terminal, code. Weights 400-700."
    },
    "google-fonts-url": {
      "$type": "string",
      "$value": "https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Instrument+Sans:wght@400..700&family=JetBrains+Mono:wght@400..700&display=swap",
      "$description": "Single stylesheet request. Axes trimmed (no SOFT, no italic for sans/mono)."
    }
  },

  "size": {
    "measure":  { "$type": "dimension", "$value": "64ch", "$description": "max line measure for prose" },
    "rail-h":   { "$type": "dimension", "$value": "56px", "$description": "top rail target height" },
    "gutter":   { "$type": "dimension", "$value": "clamp(20px, 4vw, 64px)", "$description": "responsive page gutter" },
    "grid":     { "$type": "dimension", "$value": "64px", "$description": "blueprint grid pitch" }
  },

  "radius": {
    "sm": { "$type": "dimension", "$value": "2px", "$description": "buttons, cards, chips" },
    "md": { "$type": "dimension", "$value": "4px", "$description": "terminal block" }
  },

  "border": {
    "thin":   { "$type": "strokeStyle", "$value": "solid",  "$description": "1px solid var(--rule)" },
    "dashed": { "$type": "strokeStyle", "$value": "dashed", "$description": "1px dashed var(--rule), used for card foot dividers" }
  },

  "shadow": {
    "terminal": {
      "$type": "shadow",
      "$value": [
        { "color": "rgba(0,0,0,0.4)",       "offsetX": "0", "offsetY": "12px", "blur": "36px", "spread": "0",   "inset": false },
        { "color": "rgba(255,255,255,0.02)", "offsetX": "0", "offsetY": "0",    "blur": "0",    "spread": "1px", "inset": true  }
      ],
      "$description": "The only elevation token. Cards do NOT use shadows."
    }
  },

  "breakpoint": {
    "xl": { "$type": "dimension", "$value": "1080px", "$description": "rail meta hides below this" },
    "lg": { "$type": "dimension", "$value": "880px",  "$description": "footer collapses to 3 cols" },
    "md": { "$type": "dimension", "$value": "720px",  "$description": "rail subtitle hides; footer 2 cols" },
    "sm": { "$type": "dimension", "$value": "540px",  "$description": "rail compresses; nav font shrinks" },
    "xs": { "$type": "dimension", "$value": "480px",  "$description": "mermaid hides; footer 1 col" },
    "xxs":{ "$type": "dimension", "$value": "380px",  "$description": "rail nav links collapse, only CTA remains" }
  },

  "typography": {
    "hero-display": {
      "$type": "typography",
      "$value": {
        "fontFamily":    "{font.serif}",
        "fontSize":      "clamp(60px, 12.5vw, 220px)",
        "fontWeight":    "300",
        "fontStyle":     "italic",
        "lineHeight":    "0.92",
        "letterSpacing": "-0.04em"
      },
      "$description": "Three-row hero. Fraunces opsz 144, SOFT 60-80."
    },
    "section-title": {
      "$type": "typography",
      "$value": {
        "fontFamily":    "{font.serif}",
        "fontSize":      "clamp(36px, 5.5vw, 76px)",
        "fontWeight":    "300",
        "lineHeight":    "1.0",
        "letterSpacing": "-0.025em"
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.sans}",
        "fontSize":   "17px",
        "fontWeight": "400",
        "lineHeight": "1.55"
      }
    },
    "lede": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.sans}",
        "fontSize":   "clamp(15px, 1.1vw, 18px)",
        "lineHeight": "1.6"
      }
    },
    "mono-label": {
      "$type": "typography",
      "$value": {
        "fontFamily":     "{font.mono}",
        "fontSize":       "11px",
        "fontWeight":     "700",
        "letterSpacing":  "0.18em",
        "textTransform":  "uppercase"
      },
      "$description": "Section indices, footer column labels, ID stamps."
    },
    "mono-body": {
      "$type": "typography",
      "$value": {
        "fontFamily":    "{font.mono}",
        "fontSize":      "13px",
        "fontWeight":    "400",
        "letterSpacing": "0.04em"
      },
      "$description": "Rail meta, ticker, link lists."
    }
  },

  "mermaid": {
    "background":        { "$type": "color",  "$value": "{color.ink-3}" },
    "primaryColor":      { "$type": "color",  "$value": "{color.ink-3}" },
    "primaryTextColor":  { "$type": "color",  "$value": "{color.paper}" },
    "primaryBorderColor":{ "$type": "color",  "$value": "{color.rule-2}" },
    "secondaryColor":    { "$type": "color",  "$value": "#1B1A15" },
    "tertiaryColor":     { "$type": "color",  "$value": "{color.ink-3}" },
    "lineColor":         { "$type": "color",  "$value": "{color.mute}" },
    "textColor":         { "$type": "color",  "$value": "{color.paper}" },
    "fontFamily":        { "$type": "string", "$value": "\"JetBrains Mono\", ui-monospace, monospace" },
    "fontSize":          { "$type": "string", "$value": "13px" },
    "accentBorderColor": { "$type": "color",  "$value": "{color.signal}", "$description": "applied per-node via classDef accent" }
  },

  "blueprint": {
    "grid-line-color":  { "$type": "color",     "$value": "rgba(236,227,206,0.04)" },
    "grid-pitch":       { "$type": "dimension", "$value": "64px" },
    "grid-mask":        { "$type": "string",    "$value": "linear-gradient(180deg, transparent, black 12%, black 88%, transparent)" },
    "crosshair-size":   { "$type": "dimension", "$value": "28px" },
    "crosshair-color":  { "$type": "color",     "$value": "{color.mute-2}" },
    "crosshair-offset": { "$type": "dimension", "$value": "24px" }
  },

  "grain": {
    "opacity":   { "$type": "number", "$value": 0.08 },
    "blend":     { "$type": "string", "$value": "overlay" },
    "frequency": { "$type": "number", "$value": 0.9, "$description": "feTurbulence baseFrequency" },
    "octaves":   { "$type": "number", "$value": 3 },
    "z-index":   { "$type": "number", "$value": 100 }
  },

  "vignette": {
    "gradient": { "$type": "string", "$value": "radial-gradient(ellipse at center, transparent 50%, rgba(0,0,0,0.45) 100%)" },
    "z-index":  { "$type": "number", "$value": 100 }
  },

  "focus": {
    "ring-color":  { "$type": "color",     "$value": "{color.signal}" },
    "ring-width":  { "$type": "dimension", "$value": "2px" },
    "ring-offset": { "$type": "dimension", "$value": "3px", "$description": "4px on .btn, .mcp__link, .rail__cta" }
  },

  "component": {
    "btn-primary": {
      "$description": "Default button. Outline only.",
      "fontFamily":     { "$type": "fontFamily", "$value": "{font.mono}" },
      "fontSize":       { "$type": "dimension",  "$value": "12px" },
      "letterSpacing":  { "$type": "string",     "$value": "0.1em" },
      "textTransform":  { "$type": "string",     "$value": "uppercase" },
      "padding":        { "$type": "string",     "$value": "12px 20px" },
      "border":         { "$type": "string",     "$value": "1px solid {color.rule-2}" },
      "borderRadius":   { "$type": "dimension",  "$value": "{radius.sm}" },
      "background":     { "$type": "color",      "$value": "transparent" },
      "color":          { "$type": "color",      "$value": "{color.paper}" }
    },
    "btn-accent": {
      "$description": "Primary CTA. Solid signal-orange fill.",
      "background":     { "$type": "color",     "$value": "{color.signal}" },
      "color":          { "$type": "color",     "$value": "{color.ink}" },
      "border":         { "$type": "string",    "$value": "1px solid {color.signal}" },
      "borderRadius":   { "$type": "dimension", "$value": "{radius.sm}" }
    },
    "card": {
      "$description": "Flagship and MCP cards. No shadow.",
      "background":   { "$type": "color",     "$value": "{color.ink-2}" },
      "border":       { "$type": "string",    "$value": "1px solid {color.rule}" },
      "borderRadius": { "$type": "dimension", "$value": "0" },
      "padding":      { "$type": "string",    "$value": "36px 36px 28px" },
      "topAccent":    { "$type": "string",    "$value": "1px {color.signal} top, animates 56px to 100% on hover" }
    },
    "rail": {
      "$description": "Sticky top navigation.",
      "padding":         { "$type": "string", "$value": "14px {size.gutter}" },
      "background":      { "$type": "color",  "$value": "rgba(11,11,9,0.72)" },
      "backdropFilter":  { "$type": "string", "$value": "blur(14px) saturate(140%)" },
      "borderBottom":    { "$type": "string", "$value": "1px solid {color.rule}" },
      "fontFamily":      { "$type": "fontFamily", "$value": "{font.mono}" },
      "fontSize":        { "$type": "dimension",  "$value": "12px" }
    },
    "terminal": {
      "$description": "Demo block.",
      "background": { "$type": "color",     "$value": "#0A0A07" },
      "border":     { "$type": "string",    "$value": "1px solid {color.rule}" },
      "borderRadius":{"$type": "dimension", "$value": "{radius.md}" },
      "shadow":     { "$type": "shadow",    "$value": "{shadow.terminal}" },
      "fontFamily": { "$type": "fontFamily","$value": "{font.mono}" },
      "fontSize":   { "$type": "dimension", "$value": "12.5px" },
      "lineHeight": { "$type": "number",    "$value": 1.7 }
    }
  }
}
